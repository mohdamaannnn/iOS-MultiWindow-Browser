struct ModernDustView: View { let windowSize: CGSize; @State private var particles: [DustParticle] = []; @State private var isAnimating = false; var body: some View { ZStack { ForEach(particles){ p in Circle().fill(Color.white.opacity(0.8)).frame(width: 4, height: 4).scaleEffect(isAnimating ? 0.01 : p.scale).opacity(isAnimating ? 0 : p.opacity).offset(x: isAnimating ? p.endPoint.x : p.startPoint.x, y: isAnimating ? p.endPoint.y : p.startPoint.y).animation(.easeOut(duration: Double.random(in: 0.6...1.0)), value: isAnimating) } }.onAppear{createParticles(); DispatchQueue.main.asyncAfter(deadline: .now()+0.01){isAnimating=true}} }; func createParticles() { let rows=20; let cols=20; let cw=windowSize.width/CGFloat(cols); let ch=windowSize.height/CGFloat(rows); for r in 0..<rows{for c in 0..<cols{ let sx=(CGFloat(c)*cw)-(windowSize.width/2); let sy=(CGFloat(r)*ch)-(windowSize.height/2); let sp=CGPoint(x: sx+CGFloat.random(in: -5...5), y: sy+CGFloat.random(in: -5...5)); let ep=CGPoint(x: sx+CGFloat.random(in: -40...40), y: sy-CGFloat.random(in: 20...100)); particles.append(DustParticle(startPoint: sp, endPoint: ep, scale: CGFloat.random(in: 0.5...1.5), opacity: Double.random(in: 0.5...1.0))) }} } }
